generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id          String   @id @default(cuid())
  name        String
  phone       String   @unique  // 11자리 핸드폰번호 = 로그인 아이디
  password    String
  role        Role
  supabaseId  String?  @unique  // Supabase Auth UUID (auth.users.id)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  teacher   Teacher?
  student   Student?
}

model Teacher {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  students   Student[]
  worksheets Worksheet[]
  schedules  ClassSchedule[]

  @@index([userId])
}

// ── 주간 수업 시간표 ──────────────────────────────────────────────────────────
model ClassSchedule {
  id           String  @id @default(cuid())
  teacherId    String
  teacher      Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  dayOfWeek    Int     // 0=월, 1=화, 2=수, 3=목, 4=금, 5=토, 6=일
  startTime    String  // "09:00"
  endTime      String  // "10:30"
  subject      String  // 수업 과목명
  grade        String  // 학년 (예: 중1, 고2)
  studentNames String  @default("[]") // JSON 배열 ["홍길동","김철수"]

  @@index([teacherId, dayOfWeek])
}

model Student {
  id         String   @id @default(cuid())
  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  teacherId  String
  teacher    Teacher  @relation(fields: [teacherId], references: [id])

  school      String   @default("")   // 학교명
  grade       String   @default("")   // 학년 (예: 중1, 고2)
  parentName  String   @default("")   // 보호자 이름
  parentPhone String   @default("")   // 보호자 연락처
  startDate   String   @default("")   // 수업시작일 (YYYY-MM-DD)

  currentLevel   Int         @default(1)
  currentMission MissionType @default(concept_learning)

  comprehension Float @default(0)
  reasoning     Float @default(0)
  calculation   Float @default(0)

  results       MissionResult[]
  distributions WorksheetDistribution[]

  @@index([teacherId])
}

// ── 학습지 ──────────────────────────────────────────────────────────────────
model Worksheet {
  id           String   @id @default(cuid())
  title        String
  category     String   // '단원별' | '내신대비'
  step         String   // '기초'|'기본'|'발전'|'최상위'|'최다빈출'|'최다오답'|'서술형'|'모의고사'
  examSubType  String?  // 모의고사 세부: '실전모의고사'|'기출모의고사'|'직전대비모의고사'
  grade        String   // '중1'|'중2' 등
  unit         String   @default("종합")
  problemCount Int
  source       String   @default("manual") // 'mathflat'|'manual'
  answersJson  String?  // JSON: ["①","15","2x+3",...] 문제별 정답 배열
  teacherId    String
  teacher      Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())

  distributions WorksheetDistribution[]

  @@index([teacherId])
  @@index([category, step])
}

model WorksheetDistribution {
  id           String   @id @default(cuid())
  worksheetId  String
  worksheet    Worksheet @relation(fields: [worksheetId], references: [id], onDelete: Cascade)
  studentId    String
  student      Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  status       DistributionStatus @default(distributed)
  distributedAt DateTime @default(now())

  result       WorksheetResult?

  @@unique([worksheetId, studentId])
  @@index([studentId])
  @@index([worksheetId])
}

model WorksheetResult {
  id              String   @id @default(cuid())
  distributionId  String   @unique
  distribution    WorksheetDistribution @relation(fields: [distributionId], references: [id], onDelete: Cascade)
  correctProblems Int
  submittedAt     DateTime @default(now())
}

enum DistributionStatus {
  distributed
  submitted
  graded
}

model MissionResult {
  id              String       @id @default(cuid())
  studentId       String
  student         Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  missionType     MissionType
  totalProblems   Int
  correctProblems Int
  source          ResultSource
  solvedAt        DateTime
  createdAt       DateTime     @default(now())

  @@index([studentId])
}

enum Role {
  student
  teacher
}

enum MissionType {
  concept_learning
  concept_problem
  basic_problem
  advanced_problem
  top_problem
}

enum ResultSource {
  manual
  mathflat
}
