generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  phone     String   @unique  // 11자리 핸드폰번호 = 로그인 아이디
  password  String
  role      Role
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  teacher   Teacher?
  student   Student?
}

model Teacher {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  students Student[]

  @@index([userId])
}

model Student {
  id         String   @id @default(cuid())
  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  teacherId  String
  teacher    Teacher  @relation(fields: [teacherId], references: [id])

  school     String   @default("")   // 학교명
  grade      String   @default("")   // 학년 (예: 중1, 고2)

  currentLevel   Int         @default(1)
  currentMission MissionType @default(concept_learning)

  comprehension Float @default(0)
  reasoning     Float @default(0)
  calculation   Float @default(0)

  results MissionResult[]

  @@index([teacherId])
}

model MissionResult {
  id              String       @id @default(cuid())
  studentId       String
  student         Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  missionType     MissionType
  totalProblems   Int
  correctProblems Int
  source          ResultSource
  solvedAt        DateTime
  createdAt       DateTime     @default(now())

  @@index([studentId])
}

enum Role {
  student
  teacher
}

enum MissionType {
  concept_learning
  concept_problem
  basic_problem
  advanced_problem
  top_problem
}

enum ResultSource {
  manual
  mathflat
}
