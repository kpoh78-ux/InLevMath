# ── Supabase ────────────────────────────────────────────────
# Supabase 대시보드 → Settings → API Keys 에서 확인
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="sb_publishable_..."   # Publishable key
SUPABASE_SERVICE_ROLE_KEY="eyJ..."                   # JWT Keys → service_role (절대 공개 금지)

# Supabase 대시보드 → Database → Settings → Connection pooling
# Transaction mode (포트 6543) — 앱 런타임용
DATABASE_URL="postgresql://postgres.PROJECT-REF:[password]@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Session mode (포트 5432) — Prisma 마이그레이션 전용
DIRECT_URL="postgresql://postgres.PROJECT-REF:[password]@aws-0-REGION.pooler.supabase.com:5432/postgres"

# ── 인증 ────────────────────────────────────────────────────
# 랜덤 64자 이상 문자열 — 절대 기본값 사용 금지
JWT_SECRET="change-this-to-a-random-secret-in-production"

# 학생 초기 비밀번호 (미설정 시 math1234 사용)
STUDENT_INITIAL_PASSWORD="math1234"

# ── 앱 ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
